{
  "name": "advancedplaywrightframework1x",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:debug": "playwright test --debug",
    "test:e2e": "playwright test tests/",
    "test:p0": "playwright test --grep @P0",
    "test:p1": "playwright test --grep @P1",
    "test:report": "playwright show-report",
    "test:lor": "playwright test --grep @LOR",
    "test:winston": "playwright test --reporter=list,json",
    "test:report:ci": "playwright test --reporter=html,json,junit",
    "test:allure": "playwright test --reporter=json && allure generate --clean",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "clean": "rm -rf node_modules dist && npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}
